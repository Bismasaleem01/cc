# Copy backend/.env.example to backend/.env and fill secrets before running compose.
#
# Docker compose overrides DATABASE_URL so backend can reach the db service:
# postgresql://postgres:postgres@db:5432/smart_healthcare
#
# Frontend API_BASE_URL is a Docker build arg in docker-compose.yml.
# For a real domain, build the frontend image with:
# --build-arg API_BASE_URL=https://api.your-domain.com
